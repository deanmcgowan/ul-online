# API keys for server (set these in .env for local dev, or via Secret Manager in GCP)
TRAFIKLAB_SWEDEN3_RT_KEY=your_trafiklab_sweden3_realtime_key
TRAFIKLAB_SWEDEN3_STATIC_KEY=your_trafiklab_sweden3_static_key
TRAFIKVERKET_OPEN_DATA_API_KEY=your_trafikverket_api_key

# Frontend (Vite build-time) keys
VITE_GOOGLE_STREETVIEW_KEY=your_google_streetview_api_key